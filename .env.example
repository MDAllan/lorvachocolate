# Example environment variables for LORVA Fine Chocolate
# Replace the placeholder values with your real keys in .env.local

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

NEXT_PUBLIC_RESEND_API_KEY=

NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# Better-Auth (admin portal)
BETTER_AUTH_SECRET=          # same value as NEXTAUTH_SECRET works, or generate: openssl rand -hex 32
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Admin account (only needed to run lib/auth/seed-admin.ts once)
ADMIN_EMAIL=info@lorvachocolate.com
ADMIN_PASSWORD=

DATABASE_URL=

UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

SENTRY_DSN=

# WhatsApp business number (digits only, include country code, e.g. 14161234567)
NEXT_PUBLIC_WHATSAPP_NUMBER=
